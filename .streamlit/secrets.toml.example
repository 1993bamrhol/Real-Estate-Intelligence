# Copy this file to .streamlit/secrets.toml for local development only.
# In Streamlit Community Cloud, paste the same value in App settings > Secrets.
# Prefer the Supabase transaction pooler connection string (port 6543).
DATABASE_URL = "postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Supabase Auth: copy Project URL and the publishable key from Project Settings > API Keys.
# The legacy anon key also works under SUPABASE_ANON_KEY, but prefer the publishable key.
# Never put a secret key or service_role key in this file for client authentication.
SUPABASE_URL = "https://PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY = "sb_publishable_REPLACE_ME"

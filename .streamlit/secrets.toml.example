# Copy this file to .streamlit/secrets.toml for local development only.
# In Streamlit Community Cloud, paste the same value in App settings > Secrets.
# Prefer the Supabase transaction pooler connection string (port 6543).
DATABASE_URL = "postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"
